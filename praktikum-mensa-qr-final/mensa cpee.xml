          </_notes>
        </annotations>
        <documentation>
          <input/>
          <output/>
          <implementation>
            <description/>
          </implementation>
          <code>
            <description/>
          </code>
        </documentation>
      </call>
      <call id="a2" endpoint="display">
        <parameters>
          <label>clear</label>
          <color/>
          <arguments>
            <type>set</type>
            <lx>0</lx>
            <ly>0</ly>
            <x_amount>12</x_amount>
            <y_amount>12</y_amount>
            <button/>
            <style/>
            <urls/>
            <default/>
          </arguments>
        </parameters>
        <code>
          <signal/>
          <prepare>endpoints.display += attributes.uidev</prepare>
          <finalize output="result"/>
          <update output="result"/>
          <rescue output="result"/>
        </code>
        <annotations>
          <_generic/>
          <_timing>
            <_timing_weight/>
            <_timing_avg/>
            <explanations/>
          </_timing>
          <_shifting>
            <_shifting_type>Duration</_shifting_type>
          </_shifting>
          <_context_data_analysis>
            <probes/>
            <ips/>
          </_context_data_analysis>
          <report>
            <url/>
          </report>
          <_notes>
            <_notes_general/>
          </_notes>
        </annotations>
        <documentation>
          <input/>
          <output/>
          <implementation>
            <description/>
          </implementation>
          <code>
            <description/>
          </code>
        </documentation>
      </call>
      <loop mode="post_test" condition="data.state != 'abort'">
        <_probability>
          <_probability_min/>
          <_probability_max/>
          <_probability_avg/>
        </_probability>
        <choose mode="exclusive" label="">
          <alternative condition="data.state == 'intro'">
            <_probability>
              <_probability_min/>
              <_probability_max/>
              <_probability_avg/>
            </_probability>
            <call id="a6" endpoint="display">
              <parameters>
                <label>show main</label>
                <color/>
                <arguments>
                  <type>wait</type>
                  <lx>0</lx>
                  <ly>0</ly>
                  <x_amount>12</x_amount>
                  <y_amount>12</y_amount>
                  <button/>
                  <style/>
                  <urls>
                    <urls_item>
                      <lang>de-at</lang>
                      <url>!"https://lehre.bpm.in.tum.de/~ge93fuw/qr/cpee-qr.html?view=" + data.state</url>
                    </urls_item>
                  </urls>
                  <default/>
                </arguments>
              </parameters>
              <code>
                <signal/>
                <prepare>endpoints.display += attributes.uidev</prepare>
                <finalize output="result">cmd = {}
begin
  cmd = JSON.parse(result.to_s)
rescue
  cmd = {}
end
event = cmd['action']  || ''
can   = cmd['canteen'] || data.selected_canteen
st    = data.state || 'intro'
data.last_update_raw = result.to_s

case st
when 'intro'
  if event == 'show-list'
    data.state = 'list'
    data.selected_canteen = ''
  elsif event == 'exit'
    data.state = 'abort'
    data.selected_canteen = ''
  else
    data.state = 'intro'
  end
else
  data.state = 'intro'
  data.selected_canteen = ''
end
data.event = ''</finalize>
                <update output="result"/>
                <rescue output="result"/>
              </code>
              <annotations>
                <_generic/>
                <_timing>
                  <_timing_weight/>
                  <_timing_avg/>
                  <explanations/>
                </_timing>
                <_shifting>
                  <_shifting_type>Duration</_shifting_type>
                </_shifting>
                <_context_data_analysis>
                  <probes/>
                  <ips/>
                </_context_data_analysis>
                <report>
                  <url/>
