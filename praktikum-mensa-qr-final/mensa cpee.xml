  <description>
    <description xmlns="http://cpee.org/ns/description/1.0">
      <call id="a1" endpoint="init">
        <parameters>
          <label>Init Frame</label>
          <color/>
          <arguments>
            <style_url>https://cpee.org/form/frames.css</style_url>
            <document_url/>
            <x_amount>12</x_amount>
            <y_amount>12</y_amount>
            <lang>de-at</lang>
            <document_name>My dev view</document_name>
          </arguments>
        </parameters>
        <code>
          <signal/>
          <prepare>endpoints.init += attributes.uidev</prepare>
          <finalize output="result"/>
          <update output="result"/>
          <rescue output="result"/>
        </code>
        <annotations>
          <_generic/>
          <_timing>
            <_timing_weight/>
            <_timing_avg/>
            <explanations/>
          </_timing>
          <_shifting>
            <_shifting_type>Duration</_shifting_type>
          </_shifting>
          <_context_data_analysis>
            <probes/>
