          </alternative>
          <alternative condition="data.state == 'menu'">
            <_probability>
              <_probability_min/>
              <_probability_max/>
              <_probability_avg/>
            </_probability>
            <call id="a9" endpoint="display">
              <parameters>
                <label>show menu</label>
                <color/>
                <arguments>
                  <type>wait</type>
                  <lx>0</lx>
                  <ly>0</ly>
                  <x_amount>12</x_amount>
                  <y_amount>12</y_amount>
                  <button/>
                  <style/>
                  <urls>
                    <urls_item>
                      <lang>de-at</lang>
                      <url>!"https://lehre.bpm.in.tum.de/~ge93fuw/qr/cpee-qr.html?view=menu&amp;canteen=" + data.selected_canteen</url>
                    </urls_item>
                  </urls>
                  <default/>
                </arguments>
              </parameters>
              <code>
                <signal/>
                <prepare>endpoints.display += attributes.uidev</prepare>
                <finalize output="result">cmd = {}
begin
  cmd = JSON.parse(result.to_s)
rescue
  cmd = {}
end
event = cmd['action']  || ''
can   = cmd['canteen'] || data.selected_canteen
st    = data.state || 'intro'
data.last_update_raw = result.to_s

case st
when 'menu'
  if event == 'back-list'
    data.state = 'list'
  elsif event == 'back-main'
    data.state = 'intro'
    data.selected_canteen = ''
  elsif event == 'exit'
    data.state = 'abort'
    data.selected_canteen = ''
  else
    data.state = 'intro'
    data.selected_canteen = ''
  end
else
  data.state = 'intro'
  data.selected_canteen = ''
end
data.event = ''</finalize>
